{
  "name": "@priv-kit/website",
  "private": true,
  "type": "module",
  "scripts": {
    "type-check": "tsc",
    "dev": "vitepress dev .",
    "check": "pnpm type-check && node scripts/check-docs.ts",
    "build": "pnpm check && vitepress build .",
    "preview": "vitepress preview ."
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.15",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.17.0",
      "onFail": "error"
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitepress": "catalog:"
  }
}
